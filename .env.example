# ─────────────────────────────────────────────────────────────────────────────
# CryptoVault — Root Environment (used by Docker Compose)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your own values below
#   3. NEVER commit .env — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ── Email / Gmail SMTP ────────────────────────────────────────────────────────
# Setup Gmail App Password — NOT your real Gmail password:
# Gmail → Settings → Security → 2-Step Verification → App Passwords
MAIL_EMAIL=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-gmail-app-password

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── Frontend (Vite build args passed to Docker) ───────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
