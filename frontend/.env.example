# ─────────────────────────────────────────────────────────────────────────────
# CryptoVault — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your own values below
#   3. NEVER commit .env — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# URL where the backend API is running
# Local dev:    http://localhost:8000
# Production:   https://your-api-domain.com
VITE_API_URL=http://localhost:8000

# Google OAuth Client ID (public — safe to put here, NOT the secret!)
# Get from: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
