# ─────────────────────────────────────────────────────────────────────────────
# CryptoVault · Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your own values below
#   3. NEVER commit .env — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev:   postgresql+asyncpg://postgres:yourpassword@localhost:5432/cryptovault
# Docker:      postgresql+asyncpg://cryptovault:yourpassword@postgres:5432/cryptovault
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/cryptovault

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── App Environment ───────────────────────────────────────────────────────────
# Use "development" locally, "production" when deployed
APP_ENV=development

# ── Email / Gmail SMTP ───────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your real Gmail password)
# Setup: Gmail → Settings → Security → 2-Step Verification → App Passwords
MAIL_EMAIL=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-gmail-app-password

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── OpenAI (for AI Insights feature) ─────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
